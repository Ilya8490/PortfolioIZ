# Copy this file to .env.local for local development
# Set these values in the Vercel dashboard for production
# Never commit .env.local to version control

# Site URL — used in metadata, canonical links, sitemap, robots, and OG URLs
# Initial value: free Vercel deployment URL
# Update when a custom domain is purchased
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# Contact email — used in footer and contact section
# Update when the dedicated work email is ready
NEXT_PUBLIC_CONTACT_EMAIL=hello@example.com

# Indexing — controls robots metadata site-wide
# Set to "false" during testing, "true" only when ready to launch publicly
NEXT_PUBLIC_ALLOW_INDEXING=false
